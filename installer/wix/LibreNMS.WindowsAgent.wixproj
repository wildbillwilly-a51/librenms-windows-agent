<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <Platform>x64</Platform>
    <OutputName>librenms-windows-agent-$(ProductVersion)</OutputName>
    <ProductVersion Condition="'$(ProductVersion)' == ''">0.1.0</ProductVersion>
    <PayloadDir Condition="'$(PayloadDir)' == ''">$(MSBuildProjectDirectory)\payload</PayloadDir>
    <AssetsDir Condition="'$(AssetsDir)' == ''">$(MSBuildProjectDirectory)\assets</AssetsDir>
    <DefineConstants>ProductVersion=$(ProductVersion);PayloadDir=$(PayloadDir);AssetsDir=$(AssetsDir)</DefineConstants>
  </PropertyGroup>
</Project>
